---
import Layout from '@/layouts/layout.astro'
import BlogCard from '@/components/blog-card.astro'
import { years, postsByYear } from '@/features/post/posts'
---

<Layout title="Blog" ogpPath="blog">
  <h1 class="text-3xl font-bold mb-6">Blog</h1>

  <div class="flex flex-col gap-10">
    {
      years.map(year => (
        <section class="year-section">
          <div class="flex items-center gap-4 mb-3">
            <span class="text-sm tracking-widest text-gray-400 shrink-0">
              {year}
            </span>
            <div class="flex-1 h-px bg-gray-200" />
          </div>
          <div>
            {postsByYear[year].map(post => (
              <BlogCard
                href={post.external?.url ?? `/blog/${post.id}`}
                title={post.title}
                pubDate={post.pubDate}
                tags={post.tags}
                external={post.external}
              />
            ))}
          </div>
        </section>
      ))
    }
  </div>
</Layout>

<style>
  .year-section {
    animation: fadeUp 0.4s ease both;
  }

  .year-section:nth-child(1) {
    animation-delay: 0.05s;
  }
  .year-section:nth-child(2) {
    animation-delay: 0.1s;
  }
  .year-section:nth-child(3) {
    animation-delay: 0.15s;
  }
  .year-section:nth-child(4) {
    animation-delay: 0.2s;
  }
  .year-section:nth-child(5) {
    animation-delay: 0.25s;
  }
  .year-section:nth-child(6) {
    animation-delay: 0.3s;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
