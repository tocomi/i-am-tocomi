---
import Portrait from '@/components/portrait.astro'

const currentPath = Astro.url.pathname
---

<header class="sticky top-4 z-50 px-4">
  <nav
    class="mx-auto flex max-w-3xl items-center justify-between rounded-full border border-gray-200 bg-white/70 pl-2 pr-6 shadow-sm backdrop-blur-xs"
  >
    {
      currentPath === '/' ? (
        <span class="text-xl font-bold text-gray-900 pl-4">tocomi</span>
      ) : (
        <Portrait size={40} />
      )
    }
    <div class="flex gap-4 py-4 text-sm">
      <a
        href="/"
        class:list={[
          'transition-colors',
          currentPath === '/'
            ? 'text-blue-600 font-semibold'
            : 'text-gray-600 hover:text-gray-900',
        ]}
      >
        Home
      </a>
      <a
        href="/about/"
        class:list={[
          'transition-colors',
          currentPath.startsWith('/about')
            ? 'text-blue-600 font-semibold'
            : 'text-gray-600 hover:text-gray-900',
        ]}
      >
        About
      </a>
      <a
        href="/blog/"
        class:list={[
          'transition-colors',
          currentPath.startsWith('/blog')
            ? 'text-blue-600 font-semibold'
            : 'text-gray-600 hover:text-gray-900',
        ]}
      >
        Blog
      </a>
    </div>
  </nav>
</header>
