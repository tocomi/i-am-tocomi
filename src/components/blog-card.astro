---
import type { Blog } from '@/content/types'
import ExternalIcons from '@/components/external-icons.astro'
import { formatFullDate } from '@/utils/date-util'

type Props = Blog & {
  href: string
}

const { href, title, pubDate, tags, external } = Astro.props

const formattedDate = formatFullDate(pubDate)
---

<article class="blog-card">
  <a href={`${href}/`} class="card-link" target={external ? '_blank' : '_self'}>
    <div class="card-header">
      <div class="card-tags">
        {tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
      <time class="card-date">{formattedDate}</time>
    </div>
    <h2 class="card-title">
      {title}
      {external && <ExternalIcons platform={external.platform} />}
    </h2>
  </a>
</article>

<style>
  .blog-card {
    border-bottom: 1px solid #ebebeb;
    padding: 1.25rem 0;
  }

  .blog-card:first-child {
    padding-top: 0;
  }

  .blog-card:last-child {
    border-bottom: none;
  }

  .card-link {
    display: block;
    text-decoration: none;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.45rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    align-items: center;
  }

  .tag {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #aaa;
    border: 1px solid #e0e0e0;
    padding: 0.1rem 0.45rem;
    line-height: 1.7;
  }

  .card-date {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 11px;
    letter-spacing: 0.05em;
    color: #bbb;
    flex-shrink: 0;
  }

  .card-title {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.9rem;
    font-weight: 400;
    color: #666;
    line-height: 1.55;
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }

  .blog-card:hover .card-title {
    color: #111;
  }

  .blog-card:hover .card-date {
    color: #888;
  }
</style>
