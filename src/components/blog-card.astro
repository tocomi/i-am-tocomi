---
import type { Blog } from '@/content/types'
import ExternalIcons from '@/components/external-icons.astro'
import { formatFullDate } from '@/utils/date-util'

type Props = Blog & {
  href: string
}

const { href, title, pubDate, tags, external } = Astro.props

const formattedDate = formatFullDate(pubDate)
---

<article class="border-b border-gray-200 py-5 first:pt-0 last:border-b-0 group">
  <a
    href={`${href}/`}
    class="block no-underline"
    target={external ? '_blank' : '_self'}
  >
    <div class="flex items-center justify-between gap-4 mb-2">
      <div class="flex flex-wrap gap-1 items-center">
        {
          tags.map(tag => (
            <span class="text-[9px] tracking-widest uppercase text-gray-500 border border-gray-300 px-1.5 leading-relaxed">
              {tag}
            </span>
          ))
        }
      </div>
      <time
        class="text-xs tracking-wider text-gray-400 shrink-0 transition-colors group-hover:text-gray-500"
      >
        {formattedDate}
      </time>
    </div>
    <h2
      class="text-base font-normal text-gray-600 leading-normal transition-colors group-hover:text-black"
    >
      {title}
      {external && <ExternalIcons platform={external.platform} />}
    </h2>
  </a>
</article>
